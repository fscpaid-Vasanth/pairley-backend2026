datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

// Legacy values (BOGO, BOGT, GROUP_DISCOUNT, BULK_PURCHASE, MEMBERSHIP_CAMPAIGN,
// PACKAGE_DEAL) are kept exactly as-is for backward compatibility — the "Legacy
// Mode" pair/group matching mechanic keeps working unchanged. All new offer
// creation should use the new mechanics below; STANDARD is the default.
enum OfferType {
  BOGO
  BOGT
  GROUP_DISCOUNT
  BULK_PURCHASE
  MEMBERSHIP_CAMPAIGN
  PACKAGE_DEAL
  STANDARD
  BUY_X_GET_Y
  FLAT_DISCOUNT
  PERCENTAGE_DISCOUNT
  CASHBACK
  COMBO
  SEASONAL
  FESTIVAL
  FLASH_DEAL
  LIMITED_QUANTITY
  LIMITED_TIME
}

// PAUSED/ARCHIVED are additive — nothing removed, existing rows/logic using
// the original 6 values are unaffected. CLOSED stays legacy-matching-only
// (never entered by STANDARD/new-mechanic offers).
enum OfferStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  EXPIRED
  CLOSED
  REJECTED
  PAUSED
  ARCHIVED
}

enum InterestStatus {
  INTERESTED
  READY_TO_BUY
  CONTACTED
  COMPLETED
  CANCELLED
}

// Module 5 — Lead Management. NEW is the default for every lead created by
// Show Interest (Module 3); the merchant progresses it from the Leads page.
enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  NOT_INTERESTED
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Claim/ownership lifecycle for a Business record — orthogonal to
// VerificationStatus (which tracks admin KYC approval). A normal, self-
// registered merchant is CLAIMED from creation (they proved phone/Google
// ownership at signup). UNCLAIMED is reserved for future AI-imported
// businesses (Pairley 2.0) that exist with no owner yet.
enum BusinessStatus {
  UNCLAIMED
  CLAIMED
  VERIFIED
  SUSPENDED
  REMOVED
}

// How a Business or Offer record originated. MANUAL covers today's
// self-service signup/offer-creation flows; the rest are reserved for
// Pairley 2.0's AI discovery pipeline and are not populated by any code yet.
enum Source {
  MANUAL
  WEBSITE
  INSTAGRAM
  FACEBOOK
  GOOGLE
  PDF
  POSTER
  ADMIN
}

// Whether a merchant wants incoming leads (Show Interest) auto-accepted or
// held for manual review. Not wired into any lead-processing logic yet —
// that lands with the Show Interest / Lead Management modules.
enum LeadAcceptanceMode {
  MANUAL
  AUTOMATIC
}

// Module 9 — AI Offer Discovery (Group B) foundation. Tracks one import
// attempt end to end (currently WEBSITE only; the Source enum's other
// values are reserved for later modules).
enum ImportJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

// Module 11 — AI Offer Standardization & Enrichment. Tracks an Offer's
// enrichment lifecycle, separate from ImportJobStatus (which tracks the
// import/extraction job itself, not what happens to the resulting offer
// afterward). NOT_ENRICHED is the default for every offer today, including
// all pre-Module-11 rows and every MANUAL (merchant self-service) offer,
// which is never a candidate for enrichment.
enum EnrichmentStatus {
  NOT_ENRICHED
  PENDING
  ENRICHED
  ENRICHMENT_FAILED
}

model Customer {
  id                  String             @id @default(uuid())
  name                String
  mobile              String             @unique
  email               String?            @unique
  password_hash       String?
  gender              String?
  date_of_birth       DateTime?
  age                 Int?
  city                String?
  state               String?
  address             String?
  pincode             String?
  profile_photo       String?
  referral_code       String?
  verification_status VerificationStatus @default(UNVERIFIED)

  // Module 6 — persisted notification preferences. Saved/retrieved only;
  // notificationService does not yet consult these on any send path
  // (deliberately out of scope for this module, per approved decision).
  notify_email    Boolean @default(true)
  notify_push     Boolean @default(true)
  notify_matching Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  interests    OfferInterest[]
  saved_offers SavedOffer[]
  ratings      Rating[]

  @@map("customers")
}

model Business {
  id                   String             @id @default(uuid())
  owner_name           String
  business_name        String
  business_type        String
  category             String
  mobile               String?            @unique // nullable as of Module 9: an AI-imported UNCLAIMED business may have no verified phone number yet — every existing self-registration path still always sets this
  email                String?            @unique // nullable: AI-imported businesses (Pairley 2.0) may have no known email
  password_hash        String? // Optional password for portal login
  address              String
  city                 String
  state                String
  pincode              String
  mall_name            String?
  aadhaar_number       String?
  aadhaar_photo        String?
  pan_number           String?
  pan_photo            String?
  gst_number           String?
  shop_photo           String?
  verification_status  VerificationStatus @default(PENDING)
  business_status      BusinessStatus     @default(UNCLAIMED) // explicitly set to CLAIMED at registration in code — see auth.service.ts
  source               Source             @default(MANUAL)
  created_by_ai        Boolean            @default(false)
  claimed_at           DateTime? // set only when an UNCLAIMED (AI-imported) business is claimed — null for normal signups
  claimed_by           String?
  subscription_id      String?
  notification_mobiles String?

  // Module 11 — AI-suggested merchant type, distinct from the existing
  // free-text business_type an admin/merchant can already set directly.
  // Advisory only; nothing reads this to gate behavior.
  suggested_merchant_type String?

  // Module 11 Phase 2 — business-level duplicate suggestions. Recommendation
  // only, exactly like the Offer-level fields: nothing here ever merges or
  // consolidates businesses automatically. Actual consolidation is a
  // Module 12 responsibility, once a merchant can verify ownership and
  // claim which business record is the real one.
  duplicate_of_business_id String?
  duplicate_score          Float?
  duplicate_reasons        String[]   @default([])
  duplicate_of             Business?  @relation("BusinessDuplicates", fields: [duplicate_of_business_id], references: [id], onDelete: SetNull)
  duplicates_of_this       Business[] @relation("BusinessDuplicates")

  // Module 12 Phase 4 — set only on the losing (REMOVED) side of a
  // confirmed admin consolidation. Deliberately separate from
  // duplicate_of_business_id above, which stays a pristine record of the
  // original AI suggestion (advisory, may never have been acted on) —
  // these three fields are the actual audit trail of what an admin did.
  consolidated_into_business_id String?
  consolidated_at               DateTime?
  consolidated_by               String? // admin id

  // Module 2: Business Profile
  logo                 String?
  cover_image          String?
  gallery_images       String[]           @default([])
  store_timing         Json? // { monday: { open, close, isClosed }, ... } — per-day hours, keyed by lowercase weekday
  geo_lat              Float?
  geo_lng              Float?
  lead_acceptance_mode LeadAcceptanceMode @default(MANUAL)
  description          String?
  website              String?
  instagram            String?
  facebook             String?
  whatsapp             String?
  support_number       String?

  // Module 8 — WhatsApp Business API lead alerts (distinct from the public
  // storefront `whatsapp` field above). When null, code treats `mobile`
  // (already OTP-verified at registration) as the effective number AND as
  // verified — `lead_whatsapp_verified` only matters once a merchant sets
  // an explicit override here. See whatsapp.service.ts's
  // resolveLeadWhatsappNumber().
  lead_whatsapp_number   String?
  lead_whatsapp_verified Boolean @default(false)
  notify_whatsapp        Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  subscriptions  Subscription[]
  offers         Offer[]
  ratings        Rating[]
  claim_requests ClaimRequest[]

  @@map("businesses")
}

model Subscription {
  id                String             @id @default(uuid())
  business_id       String
  plan_name         String // Basic, Premium
  amount            Float
  start_date        DateTime
  expiry_date       DateTime
  status            SubscriptionStatus @default(PENDING)
  payment_reference String?
  created_at        DateTime           @default(now())

  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Offer {
  id              String      @id @default(uuid())
  business_id     String
  title           String
  description     String
  offer_type      OfferType
  category        String
  original_price  Float
  offer_price     Float
  required_people Int
  joined_people   Int         @default(0)
  start_date      DateTime
  end_date        DateTime
  status          OfferStatus @default(DRAFT)
  source          Source      @default(MANUAL) // "offer_source" — reused from Module 1, shared with Business
  whatsapp_number String?

  // Legacy media — kept for migration compatibility, no longer written by new
  // code. Backfilled into cover_image/gallery_images at migration time.
  offer_image      String?
  facility_images  String[] @default([])
  facility_details String?

  // Module 3 media model — all new writes use these
  cover_image          String?
  gallery_images       String[] @default([])
  original_poster      String? // Pairley 2.0 — the raw imported poster, unused until Group B
  generated_offer_card String? // Pairley 2.0 — AI-generated card, unused until Group B

  // Location — offer coordinates override business coordinates when set;
  // otherwise the effective location is resolved as business.geo_lat/geo_lng
  // at the service layer (no geolocation logic duplicated here).
  geo_lat Float?
  geo_lng Float?

  // Pairley 2.0 preparation — schema only, no AI logic, unused until Group B.
  // Never exposed to customers (enforced at the API response layer, not here).
  confidence_score       Float?
  imported_at            DateTime?
  review_required        Boolean   @default(false)
  original_import_url    String?
  original_import_source String?
  merchant_verified      Boolean   @default(false)
  is_pairley_exclusive   Boolean   @default(false) // admin-only badge flag

  // Module 11 — canonical offer schema. subtitle/tags/keywords are additive
  // and empty/null until enrichment (Phase 3) populates them; the
  // normalization pipeline (Phase 1) does not touch these three.
  subtitle String? // short merchant-friendly tagline, distinct from title
  tags     String[] @default([]) // human-facing chips — admin-editable
  keywords String[] @default([]) // search-index terms, separate from tags
  // so search/ranking can evolve independently
  // of what's shown as chips in the UI

  // Enrichment audit trail. enrichment_confidence is a SEPARATE axis from
  // confidence_score above — confidence_score measures extraction
  // completeness (Module 9/10), enrichment_confidence measures how sure the
  // enrichment step is about its category/tag/type suggestions (Module 11).
  // enrichment_metadata carries, per suggested field: {suggested, accepted,
  // confidence, rationale} — the explainability trail Decision 6 requires.
  enrichment_status     EnrichmentStatus @default(NOT_ENRICHED)
  enrichment_confidence Float?
  enrichment_metadata   Json?

  // Duplicate detection (Module 11 Phase 2) — recommendation only, never
  // auto-merged (Decision 4). Always points at the earliest surviving
  // offer in a duplicate group, never at an intermediate one, so chains
  // stay flat. onDelete: SetNull — if the original is later removed, the
  // duplicate flag just clears rather than blocking or cascading the delete.
  duplicate_of_offer_id String?
  duplicate_score       Float?
  // Human-readable, generated once at detection time and persisted (not
  // recomputed on read) — an explainability snapshot of why this offer was
  // flagged, even if the compared-against offer later changes.
  duplicate_reasons     String[] @default([])
  duplicate_of          Offer?   @relation("OfferDuplicates", fields: [duplicate_of_offer_id], references: [id], onDelete: SetNull)
  duplicates_of_this    Offer[]  @relation("OfferDuplicates")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  business  Business        @relation(fields: [business_id], references: [id], onDelete: Cascade)
  interests OfferInterest[]
  saved_by  SavedOffer[]
  versions  OfferVersion[]

  // Module 4 — supports a future raw-SQL bounding-box pre-filter for
  // geo/radius discovery queries; current listOffers() does the distance
  // pass in-memory on an already-narrowed (status/category-filtered) set,
  // but this index is in place for when catalog size makes that worth it.
  @@index([geo_lat, geo_lng])
  @@map("offers")
}

// Append-only history — every merchant edit, AI standardization, and admin
// moderation action snapshots the offer's prior state here before applying
// changes. Never used to overwrite anything; purely additive audit trail.
model OfferVersion {
  id          String   @id @default(uuid())
  offer_id    String
  version_no  Int
  snapshot    Json // full offer field snapshot immediately before this change
  changed_by  String? // business_id, or 'ADMIN', or 'AI_IMPORT'
  change_type String // CREATED | MERCHANT_EDIT | STATUS_CHANGE | ADMIN_MODERATION | AI_IMPORT | AI_STANDARDIZATION
  created_at  DateTime @default(now())

  offer Offer @relation(fields: [offer_id], references: [id], onDelete: Cascade)

  @@map("offer_versions")
}

model OfferInterest {
  id          String         @id @default(uuid())
  offer_id    String
  customer_id String
  status      InterestStatus @default(INTERESTED)
  created_at  DateTime       @default(now())

  offer    Offer    @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@unique([offer_id, customer_id])
  @@map("offer_interests")
}

model SavedOffer {
  id          String   @id @default(uuid())
  customer_id String
  offer_id    String
  created_at  DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  offer    Offer    @relation(fields: [offer_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, offer_id])
  @@map("saved_offers")
}

model Notification {
  id                String   @id @default(uuid())
  user_id           String // Can link to Customer or Business ID
  title             String
  message           String
  notification_type String // New Offer, Partner Joined, Offer Completed, Subscription Expiry, etc.
  is_read           Boolean  @default(false)
  created_at        DateTime @default(now())

  @@map("notifications")
}

model Rating {
  id          String   @id @default(uuid())
  customer_id String
  business_id String
  rating      Int
  review      String?
  created_at  DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, business_id])
  @@map("ratings")
}

model SupportTicket {
  id          String        @id @default(uuid())
  user_id     String // Can link to Customer or Business ID
  subject     String
  description String
  status      SupportStatus @default(OPEN)
  created_at  DateTime      @default(now())

  @@map("support_tickets")
}

model Admin {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  name          String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("admins")
}

model OtpVerification {
  id         String   @id @default(uuid())
  mobile     String
  code       String
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("otp_verifications")
}

model CoBuyMessage {
  id               String   @id @default(uuid())
  deal_id          String
  sender_id        String
  sender_name      String
  text             String
  is_schedule_card Boolean  @default(false)
  day              String?
  time_slot        String?
  is_system        Boolean  @default(false)
  created_at       DateTime @default(now())

  @@map("co_buy_messages")
}

model Lead {
  id              String     @id @default(uuid())
  customer_id     String
  customer_name   String
  customer_mobile String
  offer_id        String
  offer_name      String
  shop_id         String
  shop_name       String
  created_at      DateTime   @default(now())
  // @default(now()) alongside @updatedAt: Prisma's @updatedAt alone is an
  // application-level behavior (auto-set on .update() calls), not a SQL
  // DEFAULT — `prisma db push` correctly refused to add a bare NOT NULL
  // column with no DB-level default against the 7 existing leads. The
  // explicit default backfills those rows safely; @updatedAt still keeps
  // updating it on every write going forward.
  updated_at      DateTime   @default(now()) @updatedAt
  status          LeadStatus @default(NEW)

  // No @relation fields by design — a lead is a standalone record of a
  // business's own history and must survive the customer/offer/business
  // rows it references being later deleted (see Module 4's cleanup: leads
  // do not cascade-delete with the customer, intentionally).
  @@index([shop_id, status, created_at])
  @@map("leads")
}

model PushToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  platform   String // 'web', 'android', 'ios'
  created_at DateTime @default(now())

  @@map("push_tokens")
}

// Module 8 — WhatsApp Business API send log. Standalone/no @relation fields,
// matching Lead's precedent: a record of what was actually sent must survive
// the business/customer/lead rows it references being later deleted.
// v1 logs only SENT/FAILED — Meta's delivery/read-receipt webhook events are
// deliberately deferred (see Module 8 STEP 1 decision).
model WhatsAppMessage {
  id              String   @id @default(uuid())
  business_id     String?
  customer_id     String?
  direction       String // 'OUTBOUND' | 'INBOUND'
  template        String? // template name; null for the existing inbound bot replies
  to_number       String
  status          String // 'SENT' | 'FAILED'
  error           String?
  related_lead_id String?
  created_at      DateTime @default(now())

  @@index([business_id, created_at])
  @@map("whatsapp_messages")
}

// Module 9 Phase 1 — AI Offer Discovery (Group B) repository foundation.
// One row per import attempt. Standalone/no @relation fields (same
// precedent as WhatsAppMessage above): a job's history must survive even if
// the Business/Offer it eventually produces is later deleted, and a failed
// job may never produce either. created_business_id/created_offer_id are
// populated once Phase 2+ actually create those rows — Phase 1 only
// establishes the table.
model ImportJob {
  id                  String          @id @default(uuid())
  source_type         Source          @default(WEBSITE)
  source_url          String
  status              ImportJobStatus @default(QUEUED)
  error               String?
  extracted_fields    Json?
  created_business_id String?
  created_offer_id    String?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt

  @@index([status, created_at])
  @@map("import_jobs")
}

// Module 9 Phase 4 — admin-assisted merchant claim flow for UNCLAIMED
// (AI-imported) businesses. PENDING_ADMIN_REVIEW -> ADMIN_APPROVED ->
// COMPLETED is the happy path; ADMIN_REJECTED and EXPIRED are terminal
// (EXPIRED also covers "too many failed OTP attempts" — see
// claim-request.service.ts). Every status transition is final except the
// initial PENDING_ADMIN_REVIEW -> ADMIN_APPROVED/ADMIN_REJECTED branch —
// once a token leaves ADMIN_APPROVED it can never be used again, which is
// the single-use/replay-protection mechanism, enforced in the service
// layer (not achievable via schema constraints alone).
enum ClaimRequestStatus {
  PENDING_ADMIN_REVIEW
  ADMIN_APPROVED
  ADMIN_REJECTED
  COMPLETED
  EXPIRED
}

model ClaimRequest {
  id               String             @id @default(uuid())
  business_id      String
  mobile           String
  claim_token      String             @unique
  status           ClaimRequestStatus @default(PENDING_ADMIN_REVIEW)
  token_expires_at DateTime
  otp_attempts     Int                @default(0)
  reviewed_by      String? // admin id
  reviewed_at      DateTime?
  rejection_reason String?
  completed_at     DateTime?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt

  // Module 12 Phase 1 — evidence-based self-service claims. Both additive;
  // a claim submitted before this module (or with no evidence supplied)
  // simply has claimant_name: null, evidence_urls: []. Deliberately a
  // flexible String[] rather than named fields (aadhaar_photo-style) —
  // claim evidence is plausibly a business registration certificate, a
  // storefront photo, a GST document, a rental agreement, etc., and
  // different merchants will have different combinations available.
  claimant_name String?
  evidence_urls String[] @default([])

  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id, status])
  @@map("claim_requests")
}
